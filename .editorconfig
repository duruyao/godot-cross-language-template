root = true

[*]
tab_width = 4
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{c,cc,cpp,cxx,h,hh,hpp}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
indent_size = 4

[{*.cmake,CMakeLists.txt}]
indent_style = space
ij_continuation_indent_size = 8
ij_cmake_force_commands_case = 1

[*.cs]
indent_style = space
indent_size = 4

[*.{gd,gdshader}]
indent_style = tab
indent_size = 4

[{*.gradle,AndroidManifest.xml}]
indent_style = space
indent_size = 4

[{*.py,SConstruct,SCsub,SConscript}]
indent_style = space
indent_size = 4

[*.{yml,yaml}]
indent_style = space
indent_size = 2
